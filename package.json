{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node ./preinstall.cjs",
    "dev": "pnpm --filter @workspace/furnicore dev",
    "dev:api": "pnpm --filter @workspace/api-server dev",
    "dev:stack": "concurrently -n api,web -c blue,magenta \"pnpm run dev:api\" \"pnpm run dev\"",
    "dev:api:stub": "node ./scripts/dev-api-health-stub.mjs",
    "db:up": "docker compose up -d",
    "db:up:win": "powershell -ExecutionPolicy Bypass -File ./scripts/db-up.ps1",
    "db:install-docker": "powershell -ExecutionPolicy Bypass -File ./scripts/install-docker-desktop.ps1",
    "db:install-wsl": "powershell -ExecutionPolicy Bypass -File ./scripts/install-wsl.ps1",
    "db:down": "docker compose down",
    "ports:free": "node ./scripts/kill-dev-ports.mjs",
    "setup:env": "node ./scripts/setup-local-env.mjs",
    "db:migrate": "pnpm --filter @workspace/scripts migrate",
    "db:seed-admin": "pnpm --filter @workspace/scripts seed-admin",
    "db:setup": "pnpm run db:migrate && pnpm run db:seed-admin",
    "db:up-and-setup": "pnpm run db:up && pnpm run db:setup",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./backend/**\" --filter \"./frontend/**\" --if-present run typecheck",
    "lint": "eslint backend/api-server/src frontend/furnicore/src"
  },
  "private": true,
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
