# Copy to `.env` in this folder. Vite loads it automatically.
# Use a different PORT than the API server when running both locally.

PORT=5173
BASE_PATH=/
# URL of the Express API server (origin only; do not add /api — paths already include /api/...).
# You can also set VITE_API_URL in the repo-root `.env`; furnicore merges root then this file (this file wins).
VITE_API_URL=http://localhost:3000
