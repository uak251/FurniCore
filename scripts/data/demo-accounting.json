  "meta": {
    "title": "FurniCore demo accounting — double-entry journal entries",
    "prerequisite": "Chart of accounts must exist (POST /accounts/seed as admin, or equivalent). Uses standard codes from accounts seed: 1000–6900.",
    "reportMapping": {
      "trialBalance": "All posted journal lines through `asOf` aggregate per account (debit/credit totals and signed balance). Includes every account type that has activity.",
      "profitAndLoss": "Posted lines on income/expense accounts (4000–6900) with `date` between `from` and `to`. Operating activity is dated in 2026; the year-end closing entry is dated 2027-01-02 so P&L for calendar 2026 excludes closing and shows operating revenue and expenses only.",
      "balanceSheet": "Posted lines on asset, liability, and equity accounts (1000–3100) with `date` <= `asOf`. Before closing, assets exceed liabilities+equity by the amount of net income still sitting in P&L accounts. Use `asOf` on or after 2027-01-02 (after the closing entry) for a balanced sheet with Retained Earnings reflecting net income.",
      "cashBook": "Sums the `transactions` table (income vs expense types), not journal lines. Optional demo rows are included for the cash-book report."
    }
  },
