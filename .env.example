# Copy this file to `.env` at the repo root: `cp .env.example .env` (Unix) or copy manually on Windows.
# Used by the API server and Drizzle CLI (`pnpm --filter @workspace/db run push`).

# PostgreSQL connection string (required).
#
# Local Docker (see `docker-compose.yml`):
DATABASE_URL=postgresql://furnicore:furnicore_dev@localhost:5432/furnicore
#
# Windows: Docker Desktop needs WSL 2 for Linux containers. If `pnpm run db:up` fails:
#   Admin PowerShell → .\scripts\install-wsl.ps1  (reboot if asked) → start Docker Desktop → db:up
# Or install Docker only: .\scripts\install-docker-desktop.ps1
#
# Supabase — Project Settings → Database → copy the URI (use your DB password).
# Direct connection host looks like: db.<project-ref>.supabase.co
# Example (replace password; URL-encode special characters in the password):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.wvyjaywrfuwpvfxwbpuc.supabase.co:5432/postgres
#
# Optional — hosted Postgres (Supabase/Neon): strict TLS verification (default off; set true in production if your network trusts the CA chain).
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Optional — bootstrap / reset the primary admin (pnpm --filter @workspace/scripts seed-admin)
# Defaults: admin@furnicore.com / Admin@123456
# ADMIN_EMAIL=admin@furnicore.com
# ADMIN_PASS=Admin@123456
# ADMIN_NAME=Master Admin

# API listen port (required by @workspace/api-server)
PORT=3000

# Optional — picked up by the FurniCore Vite app (see frontend/furnicore/vite.config.js)
# so the dev proxy and client API base URL match this origin. Use the same port as PORT above, e.g. http://localhost:3000
# VITE_API_URL=http://localhost:3000

# JWT/session signing (set a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-secret

# Optional: pino log level (e.g. debug, info, warn, error)
# LOG_LEVEL=info

# ─── Email verification (nodemailer / Gmail SMTP) ─────────────────────────────
# The public URL of your frontend — used to build the verification link.
APP_URL=http://localhost:5173

# Set to "false" to skip sending emails and print the verification URL to the
# console instead (useful in local development without a real SMTP account).
EMAIL_ENABLED=false

# Gmail address used as the sender.
SMTP_USER=noreply@yourcompany.com

# Gmail App Password (NOT your regular password).
# Enable 2-Step Verification, then: Google Account → Security → App Passwords.
SMTP_PASS=your-gmail-app-password

# Optional — override SMTP host/port if not using Gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# Optional — custom "From" header (defaults to "FurniCore ERP <{SMTP_USER}>")
# SMTP_FROM=FurniCore ERP <noreply@yourcompany.com>

# Secret used to sign email-verification JWTs (different from SESSION_SECRET).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_VERIFY_SECRET=change-me-to-another-long-random-secret

# ─── Power BI Integration (optional) ──────────────────────────────────────────
# Required only if you want to embed Power BI dashboards in the Accounting module.
# See: https://learn.microsoft.com/en-us/power-bi/developer/embedded/embed-service-principal
#
# 1. Register an Azure AD app (App registrations → New registration).
# 2. Grant it: Power BI Service → Report.ReadAll (Application permission) → admin-consent.
# 3. In Power BI Service: workspace → Settings → Access → add the app as "Member".
# 4. Publish your reports (Supplier Ledger, Expense vs Income, Payroll, Profit Margin)
#    to that workspace, then copy each report ID from the Power BI URL.
#
POWERBI_TENANT_ID=your-azure-tenant-id
POWERBI_CLIENT_ID=your-azure-app-client-id
POWERBI_CLIENT_SECRET=your-azure-app-client-secret
POWERBI_WORKSPACE_ID=your-powerbi-workspace-group-id
POWERBI_REPORT_SUPPLIER_LEDGER=report-id-for-supplier-ledger
POWERBI_REPORT_EXPENSE_INCOME=report-id-for-expense-vs-income
POWERBI_REPORT_PAYROLL_SUMMARY=report-id-for-payroll-summaries
POWERBI_REPORT_PROFIT_MARGIN=report-id-for-profit-margin
