# Copy to `.env` in this folder. Vite loads it automatically.
# Use a different PORT than the API server when running both locally.

PORT=5173
BASE_PATH=/
# URL of the Express API server (origin only; do not add /api — paths already include /api/...).
# You can also set VITE_API_URL in the repo-root `.env`; furnicore merges root then this file (this file wins).
VITE_API_URL=http://localhost:3000
#
# Production (Vercel SPA → Railway API): set VITE_API_URL in the Vercel project to your Railway HTTPS origin, e.g.
#   https://your-service.up.railway.app
# Dashboard: Project → Settings → Environment Variables → Production, then redeploy.
# Or: pnpm run deploy:vercel -- https://your-service.up.railway.app
# Your production site URL is under Vercel → Project → Domains.
