# Copy to `.env` in this folder. Vite loads it automatically.
# Use a different PORT than the API server when running both locally.

PORT=5173
BASE_PATH=/
# URL of the Express API server (include /api suffix).
# Railway production example:
# VITE_API_URL=https://your-backend-service.up.railway.app/api
#
# Local dev: leave VITE_API_URL unset so the browser calls /api on the Vite host and Vite proxies
# to the API. The proxy target defaults to http://127.0.0.1:3000 (api-server PORT). If your API
# runs elsewhere, set for example:
# VITE_DEV_API_ORIGIN=http://127.0.0.1:3001
# Do not set VITE_API_URL to an empty string — that breaks the proxy.
# VITE_API_URL=https://furnicorebackend-production.up.railway.app/api
