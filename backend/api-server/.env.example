# Backend environment (Express API) - copy to `.env` at repo root or `backend/.env`.

# =========================
# APP CONFIG
# =========================
NODE_ENV=development
PORT=3000
APP_URL=https://furnicore-theta.vercel.app
FRONTEND_URL=https://furnicore-theta.vercel.app
CORS_ORIGIN=https://furnicore-theta.vercel.app

# =========================
# DATABASE (Primary)
# =========================
# Preferred source:
DATABASE_URL=postgresql://postgres:Subhanallah123@db.wvyjaywrfuwpvfxwbpuc.supabase.co:5432/postgres

# Optional split fallback (used only when DATABASE_URL is missing):
DB_HOST=db.wvyjaywrfuwpvfxwbpuc.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=Subhanallah123

# TLS / connectivity helpers
DATABASE_SSL_REJECT_UNAUTHORIZED=false
# API blocks auth until DB probe succeeds; timeout must be >= pg pool connection timeout (~8s). Raise for slow Supabase.
# DB_HEALTH_PROBE_TIMEOUT_MS=20000
