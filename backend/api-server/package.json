{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm run build && pnpm run start:dist",
    "check:rbac-contract": "node ./scripts/check-rbac-contract.mjs",
    "check:db": "node ./scripts/check-db-connection.mjs",
    "build": "pnpm run check:rbac-contract && node ./build.mjs",
    "start": "pnpm run build && pnpm run start:dist",
    "start:win": "node ./scripts/set-pghostaddr-win.mjs",
    "start:dist": "node --enable-source-maps ./dist/index.mjs",
    "migrate": "pnpm -C ../../ run db:migrate",
    "seed-admin": "pnpm -C ../../ run db:seed-admin",
    "test:login:railway": "node ./scripts/railway-login-smoke.mjs",
    "test:dashboard:railway": "node ./scripts/railway-dashboard-analytics-smoke.mjs",
    "typecheck": "node -e \"process.exit(0)\"",
    "lint": "eslint src",
    "test": "pnpm run check:rbac-contract && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/uuid": "^11.0.0",
    "@workspace/api-zod": "file:./lib/api-zod",
    "@workspace/db": "file:./lib/db",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5",
    "firebase-admin": "^13.8.0",
    "json2csv": "6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "supertest": "^7.0.0",
    "thread-stream": "3.1.0",
    "vitest": "^3.1.1"
  }
}
